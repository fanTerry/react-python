# Docker 部署（PostgreSQL）
FRONTEND_PORT=8080
JWT_SECRET=please-change-this-to-a-random-32-char-secret
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:8080

POSTGRES_USER=blog
POSTGRES_PASSWORD=blog
POSTGRES_DB=blog

# 本地开发可不设置 DATABASE_URL，默认使用 backend/todos.db（SQLite）
# DATABASE_URL=postgresql://blog:blog@localhost:5432/blog
