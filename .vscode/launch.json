{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI 调试（推荐）",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app:app", "--port", "8999"],
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": true
    },
    {
      "name": "FastAPI 调试（热重载）",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app:app", "--reload", "--port", "8999"],
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": true,
      "subProcess": true
    }
  ]
}
